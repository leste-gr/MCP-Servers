FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY troubleshooting_mcp_server ./troubleshooting_mcp_server

ENV MCP_TRANSPORT=streamable-http \
    MCP_HOST=0.0.0.0 \
    MCP_PORT=8012 \
    MCP_PATH=/mcp

EXPOSE 8012

CMD ["python", "-m", "troubleshooting_mcp_server.server"]