FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY tmf638_mcp_server ./tmf638_mcp_server

ENV TMF638_BASE_URL=http://tmf638-backend:8081/tmf-api/serviceInventory/v5 \
    MCP_TRANSPORT=streamable-http \
    MCP_HOST=0.0.0.0 \
    MCP_PORT=8001 \
    MCP_PATH=/mcp

EXPOSE 8001

CMD ["python", "-m", "tmf638_mcp_server.server"]
